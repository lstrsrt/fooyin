on run argv
    set volumeName to item 1 of argv

    tell application "Finder"
        tell disk volumeName
            set openAttempts to 0
            repeat while openAttempts < 4
                try
                    open
                    delay 1
                    close
                    set openAttempts to 5
                on error
                    set openAttempts to openAttempts + 1
                    delay 5
                end try
            end repeat
            delay 2

            open
            delay 2

            set current view of container window to icon view
            set theViewOptions to the icon view options of container window
            set arrangement of theViewOptions to not arranged
            set icon size of theViewOptions to 128
            set text size of theViewOptions to 14
            set background picture of theViewOptions to file ".background:background.png"
            delay 3
            close
            delay 1

            open
            delay 2

            set toolbar visible of container window to false
            set statusbar visible of container window to false
            set pathbar visible of container window to false
            set sidebar width of container window to 0
            set bounds of container window to {120, 120, 800, 540}
            set position of item "@FOOYIN_BUNDLE_NAME@" of container window to {150, 215}
            set position of item "Applications" of container window to {520, 215}
            try
                set position of item ".background" of container window to {900, 500}
            end try
            try
                set position of item ".fseventsd" of container window to {980, 500}
            end try
            try
                set position of item ".Trashes" of container window to {1060, 500}
            end try

            update without registering applications
            delay 3
            close
        end tell
        delay 1
    end tell
end run
